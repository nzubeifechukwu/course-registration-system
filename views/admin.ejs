<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 h-fit">
        <h2 class="text-xl font-bold mb-4 text-gray-800">Create New Course</h2>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 text-sm text-center font-medium">
            <%= error %>
          </div>
        <% } %>

        <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
          <div class="bg-red-50 border border-red-300 text-red-700 px-4 py-3 rounded mb-4 text-sm font-medium">
            <p class="font-bold mb-1 text-red-800">Validation Failures:</p>
            <ul class="list-disc list-inside space-y-0.5 text-xs text-red-600">
              <% errors.forEach(function(err) { %>
                <li><%= err.message %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
        
        <form action="/admin/course" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Course Title</label>
            <input type="text" name="title" value="<%= typeof oldData !== 'undefined' ? oldData.title : '' %>" required placeholder="e.g., GSP 101" class="mt-1 block w-full p-2.5 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:ring-indigo-500 focus:border-indigo-500">
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700">Target Level</label>
            <select name="level" required class="mt-1 block w-full p-2.5 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:ring-indigo-500 focus:border-indigo-500">
              <option value="100" <%= typeof oldData !== 'undefined' && oldData.level === 100 ? 'selected' : '' %>>100 Level</option>
              <option value="200" <%= typeof oldData !== 'undefined' && oldData.level === 200 ? 'selected' : '' %>>200 Level</option>
              <option value="300" <%= typeof oldData !== 'undefined' && oldData.level === 300 ? 'selected' : '' %>>300 Level</option>
              <option value="400" <%= typeof oldData !== 'undefined' && oldData.level === 400 ? 'selected' : '' %>>400 Level</option>
            </select>
          </div>
          
          <button type="submit" class="w-full bg-indigo-600 text-white p-2.5 rounded font-semibold hover:bg-indigo-700 transition shadow-sm">
            Add Course
          </button>
        </form>
      </div>
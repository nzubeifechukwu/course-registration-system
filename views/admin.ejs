<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Course Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  
  <nav class="bg-indigo-900 text-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center">
          <span class="font-bold text-xl tracking-wider">PORTAL // ADMIN</span>
        </div>
        <div class="flex items-center space-x-4">
          <span class="text-sm bg-indigo-800 px-3 py-1 rounded">Logged in as: <%= user.name %></span>
          <form action="/logout" method="POST" class="inline">
            <button type="submit" class="bg-red-600 hover:bg-red-700 px-3 py-1.5 rounded text-sm font-semibold transition">
              Log Out
            </button>
          </form>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 h-fit">
        <h2 class="text-xl font-bold mb-4 text-gray-800">Create New Course</h2>
        
        <form action="/admin/course" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Course Title</label>
            <input type="text" name="title" required placeholder="e.g., GSP 101" class="mt-1 block w-full p-2.5 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:ring-indigo-500 focus:border-indigo-500">
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700">Target Level</label>
            <select name="level" required class="mt-1 block w-full p-2.5 border border-gray-300 rounded bg-gray-50 text-gray-900 focus:ring-indigo-500 focus:border-indigo-500">
              <option value="100">Level 100</option>
              <option value="200">Level 200</option>
              <option value="300">Level 300</option>
              <option value="400">Level 400</option>
            </select>
          </div>
          
          <button type="submit" class="w-full bg-indigo-600 text-white p-2.5 rounded font-semibold hover:bg-indigo-700 transition shadow-sm">
            Add Course
          </button>
        </form>
      </div>

      <div class="lg:col-span-2 space-y-8">
        
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
            <h2 class="text-xl font-bold mb-4 text-gray-800">Active Courses</h2>
            <% if (courses && courses.length > 0) { %>
            <div class="overflow-x-auto">
            <table class="w-full min-w-full divide-y divide-gray-200 table-fixed">
                <thead class="bg-gray-50">
                <tr>
                    <th class="w-3/4 px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
                    <th class="w-1/4 px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Target Level</th>
                </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200 text-sm text-gray-700">
                <% courses.forEach(course => { %>
                    <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 font-medium text-gray-900 truncate"><%= course.title %></td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
                        Level <%= course.level %>
                        </span>
                    </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
            </div>
        <% } else { %>
            <p class="text-sm text-gray-500 py-4">No courses have been created yet.</p>
        <% } %>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
          <h2 class="text-xl font-bold mb-4 text-gray-800">Registered Students</h2>
          <% if (students && students.length > 0) { %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Level</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Registered Courses</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200 text-sm text-gray-700">
                  <% students.forEach(student => { %>
                    <tr>
                      <td class="px-6 py-4 font-medium text-gray-900"><%= student.name %></td>
                      <td class="px-6 py-4"><%= student.email %></td>
                      <td class="px-6 py-4">Level <%= student.level %></td>
                      <td class="px-6 py-4">
                        <% if (student.registrations && student.registrations.length > 0) { %>
                          <div class="flex flex-wrap gap-1">
                            <% student.registrations.forEach(reg => { %>
                              <span class="inline-block bg-indigo-100 text-indigo-800 text-xs px-2 py-0.5 rounded font-medium">
                                <%= reg.course.title %>
                              </span>
                            <% }) %>
                          </div>
                        <% } else { %>
                          <span class="text-xs text-gray-400 italic">No courses registered</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-sm text-gray-500 py-4">No students have signed up yet.</p>
          <% } %>
        </div>

      </div>
    </div>
  </main>

</body>
</html>
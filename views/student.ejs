<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Dashboard - Course Portal</title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-gray-100 min-h-screen">
  
  <nav class="bg-slate-900 text-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center">
          <span class="font-bold text-xl tracking-wider">STUDENT // PORTAL</span>
        </div>
        <div class="flex items-center space-x-4">
          <span class="text-sm bg-slate-800 px-3 py-1 rounded">Academic Level: <%= user.level %></span>
          <form action="/logout" method="POST" class="inline">
            <button type="submit" class="bg-red-600 hover:bg-red-700 px-3 py-1.5 rounded text-sm font-semibold transition">
              Log Out
            </button>
          </form>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-8">
      <h1 class="text-2xl font-bold text-gray-800">Welcome back, <%= user.name %>!</h1>
      <p class="text-sm text-gray-600 mt-1">Manage your active course curriculum selections below for Level <%= user.level %>.</p>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
      <h2 class="text-xl font-bold mb-6 text-gray-800">Curriculum Course Catalog</h2>
      
      <% if (courses && courses.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Course Name</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Curriculum Level</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200 text-sm text-gray-700">
              <% courses.forEach(course => { %>
                <tr>
                  <td class="px-6 py-4 font-medium text-gray-900"><%= course.title %></td>
                  <td class="px-6 py-4">Level <%= course.level %></td>
                  <td class="px-6 py-4">
                    <% if (course.isEnrolled) { %>
                      <span class="px-2.5 py-1 text-xs font-semibold bg-green-100 text-green-800 rounded-full">Enrolled</span>
                    <% } else { %>
                      <span class="px-2.5 py-1 text-xs font-semibold bg-gray-100 text-gray-600 rounded-full">Not Registered</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <% if (course.isEnrolled) { %>
                      <form action="/student/course/drop" method="POST" class="inline">
                        <input type="hidden" name="courseId" value="<%= course.id %>">
                        <button type="submit" class="bg-red-100 hover:bg-red-200 text-red-700 px-3 py-1.5 rounded text-xs font-bold transition">
                          Drop Course
                        </button>
                      </form>
                    <% } else { %>
                      <form action="/student/course/register" method="POST" class="inline">
                        <input type="hidden" name="courseId" value="<%= course.id %>">
                        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5 rounded text-xs font-bold transition shadow-sm">
                          Register
                        </button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-8">
          <p class="text-sm text-gray-500">There are no courses listed for your academic level at this time.</p>
        </div>
      <% } %>
    </div>
  </main>

</body>
</html>
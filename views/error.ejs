<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 h-screen flex flex-col items-center justify-center p-4">
  <div class="bg-white p-8 rounded-lg shadow-md max-w-lg w-full text-center">
    <h1 class="text-3xl font-bold text-red-600 mb-2"><%= title %></h1>
    <p class="text-gray-700 mb-6"><%= message %></p>
    <% if (error && error.stack) { %>
      <pre class="bg-gray-900 text-green-400 text-left text-xs p-4 rounded overflow-x-auto max-h-40 mb-6"><%= error.stack %></pre>
    <% } %>
    <a href="/" class="bg-indigo-600 text-white px-4 py-2 rounded font-semibold hover:bg-indigo-700 transition">Return to Home Portal</a>
  </div>
</body>
</html>